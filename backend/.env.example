# ── ATLAS backend configuration ──────────────────────────────
# Copy to .env and adjust. Every service runs on localhost only.

# Ollama — llama3.2:3b is fast on 8 GB machines; use llama3.1 (8B) with 16 GB+
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Whisper (tiny | base | small | medium | large-v3) — tiny is fastest
WHISPER_MODEL=tiny

# Piper voice model (.onnx). Download via scripts/setup.sh
PIPER_VOICE=models/en_US-ryan-high.onnx

# SQLite database file
DATABASE_PATH=data/atlas.db

# File-search roots the assistant may access (comma-separated absolute paths).
# Empty = file search disabled. NEVER add system directories.
ALLOWED_SEARCH_ROOTS=

# Frontend origin allowed by CORS
FRONTEND_ORIGIN=http://localhost:3000
